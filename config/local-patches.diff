+        f.write_text(json.dumps(_valid_input()))
+        result = subprocess.run(
+            [sys.executable, "-m", "scoring.cli", "--input", str(f)],
+            capture_output=True,
+            text=True,
+            cwd=str(REPO),
+        )
+        assert result.returncode == 0
+        output = json.loads(result.stdout)
+        assert "global_score" in output
